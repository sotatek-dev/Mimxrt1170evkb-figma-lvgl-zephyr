<screen>
	<styles>
		<style
			name="style_order_screen"
			figma_node_id="51:10"
			bg_color="0x281414"
			bg_opa="100%"
			pad_all="0"
			border_width="0"
		/>
		<style
			name="style_brewing_text"
			figma_node_id="51:14"
			text_color="0xc9c0b9"
			text_font="font_brewing"
			text_align="left"
			width="344"
			height="112"
		/>
		<style
			name="style_progress_bar"
			figma_node_id="51:26"
			bg_color="0xe0d6d0"
			bg_opa="100%"
			radius="8"
			pad_all="0"
			border_width="0"
			width="300"
			height="16"
		/>
		<style name="style_progress_indicator" bg_color="0x8b4a3b" bg_opa="100%" radius="8" />
		<style
			name="style_progress_status"
			figma_node_id="51:30"
			bg_opa="0%"
			text_color="0xffffff"
			text_font="font_status"
			text_align="left"
			width="241"
			height="70"
		/>
		<style name="style_selected_drink_image" radius="0" />
	</styles>

	<view width="1280" height="720">
		<style name="style_order_screen" />

		<lv_label text="Brewing" x="217" y="128" width="344" height="112">
			<style name="style_brewing_text" />
		</lv_label>

		<lv_bar name="brew_progress_bar" x="171" y="273" width="285" height="16" value="35">
			<style name="style_progress_bar" />
			<style name="style_progress_indicator" selector="indicator" />
		</lv_bar>

		<lv_label name="brew_progress_status" text="Add Coffee..." x="223" y="436" width="241" height="70">
			<style name="style_progress_status" />
		</lv_label>

		<lv_image name="selected_drink_image" src="caramel_frappe" x="640" y="0" width="640" height="720">
			<style name="style_selected_drink_image" />
		</lv_image>
	</view>
</screen>
